{
    "name": "kilyakus/cherryii",
    "version": "dev-master",
    "description": "«CHERRYII» CMS",
    "keywords": ["cherryii"],
    "homepage": "http://cherryiicms.com",
    "type": "yii2-extension",
    "license": "CC BY-NC 4.0",
    "minimum-stability": "dev",
    "support": {
        "wiki": "http://cherryiicms.com/docs",
        "source": "https://github.com/kilyakus/cherryii.git",
        "issues": "https://github.com/kilyakus/cherryii/issues"
    },
    "authors": [
        {
            "name": "Aleksandr Kilyakov",
            "email": "aleksandr.kilyakov@gmail.com",
            "role" : "Developer"
        },
        {
            "name": "Simon Semin",
            "role" : "Sponsor"
        }
    ],
    "require": {
        "php": ">=8.0.0",
        "yiisoft/yii2": "~2.0.45",
        "yiisoft/yii2-bootstrap5": "~2.0.0",
        "npm-asset/bootstrap": "5.3.8",
        "yiisoft/yii2-swiftmailer": "~2.1.0",
        "creocoder/yii2-nested-sets": "0.9.*",
        "bower-asset/fancybox": "2.1.5",
        "bower-asset/jquery.switcher": "*",
        "bower-asset/eonasdan-bootstrap-datetimepicker": "^4.7@dev",
        "bower-asset/jquery": "2.1.4",
        "2amigos/yii2-selectize-widget": "~1.0"
    },
    "autoload": {
        "psr-4": {
            "yii\\cherryii\\": "/"
        }
    },
    "extra": {
        "asset-installer-paths": {
            "npm-asset-library": "vendor/npm-asset",
            "bower-asset-library": "vendor/bower-asset"
        }
    }
}