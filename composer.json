{
    "name": "kilyakus/cherryii",
    "version": "dev-master",
    "description": "«CHERRYII» CMS",
    "keywords": ["cherryii"],
    "homepage": "http://cherryiicms.com",
    "type": "yii2-extension",
    "license": "GNU GPL V3",
    "minimum-stability": "dev",
    "support": {
        "wiki": "http://cherryiicms.com/docs",
        "source": "https://github.com/kilyakus/cherryii.git",
        "issues": "https://github.com/kilyakus/cherryii/issues"
    },
    "authors": [
        {
            "name": "Aleksandr Kilyakov",
            "email": "aleksandr.kilyakov@gmail.com",
            "role" : "Developer"
        },
        {
            "name": "Simon Semin",
            "role" : "Sponsor"
        }
    ],
    "require": {
        "php": ">=5.4.0",
        "yiisoft/yii2": "*",
        "yiisoft/yii2-bootstrap": "*",
        "yiisoft/yii2-swiftmailer": "*",
        "creocoder/yii2-nested-sets": "0.9.*",
        "bower-asset/fancybox": "*",
        "bower-asset/jquery.switcher": "*",
        "bower-asset/eonasdan-bootstrap-datetimepicker": "^4.7@dev",
        "2amigos/yii2-selectize-widget": "~1.0"
    },
    "autoload": {
        "psr-4": {
            "yii\\cherryii\\": "/"
        }
    },
    "extra": {
        "asset-installer-paths": {
            "npm-asset-library": "vendor/npm",
            "bower-asset-library": "vendor/bower"
        }
    }
}
